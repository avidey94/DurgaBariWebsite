ADMIN_EMAILS=

# Data provider
DATA_PROVIDER=mock
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_GID=0
GOOGLE_SHEETS_CLIENT_EMAIL=
GOOGLE_SHEETS_PRIVATE_KEY=

# Payments
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional content
NEXT_PUBLIC_YOUTUBE_LIVE_EMBED_URL=
